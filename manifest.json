{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_shortName__",
  "version": "1.0.0",
  "version_name": "1.0.0 beta",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_extensionSingleName__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "homepage_url": "https://lucabracaloni.it",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.google.com/search*",
    "https://www.google.it/search*",
    "https://www.google.co.uk/search*",
    "https://www.google.de/search*",
    "https://www.google.fr/search*",
    "https://www.google.es/search*",
    "https://lume-proxy-server.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.it/search*",
        "https://www.google.co.uk/search*",
        "https://www.google.de/search*",
        "https://www.google.fr/search*",
        "https://www.google.es/search*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}